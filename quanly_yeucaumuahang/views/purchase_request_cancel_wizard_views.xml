<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_request_cancel_wizard_form" model="ir.ui.view">
        <field name="name">purchase.request.cancel.wizard.form</field>
        <field name="model">purchase.request.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Từ chối yêu cầu mua hàng">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="reason" placeholder="Nhập lý do từ chối..."/>
                </group>

                <footer>
                    <button name="action_confirm_cancel"
                            string="Xác nhận từ chối"
                            type="object"
                            class="btn-primary"/>

                    <button string="Hủy"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>