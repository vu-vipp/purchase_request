<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_request_export_wizard_form" model="ir.ui.view">
        <field name="name">purchase.request.export.wizard.form</field>
        <field name="model">purchase.request.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Xuất Excel" create="false" edit="false">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="file_name" invisible="1"/>
                    <field name="file_data"
       filename="file_name"
       widget="binary"
       readonly="1"/>
                </group>

                <footer>
                    <button string="Đóng"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>