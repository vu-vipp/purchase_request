<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_request_tree" model="ir.ui.view">
        <field name="name">purchase.request.tree</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="department_id"/>
                <field name="request_id"/>
                <field name="approver_id"/>
                <field name="date"/>
                <field name="date_approve"/>
                <field name="state"/>
                <field name="total_qty"/>
                <field name="total_amount"/>
            </tree>
        </field>
    </record>

    <record id="view_purchase_request_form" model="ir.ui.view">
        <field name="name">purchase.request.form</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <form string="Yêu cầu mua hàng">
                <header>
    <button name="action_submit"
            string="Gửi yêu cầu"
            type="object"
            class="oe_highlight"
            states="draft"/>

    <button name="action_back_to_draft"
            string="Quay lại"
            type="object"
            states="wait"/>

    <button name="action_approve"
            string="Phê duyệt"
            type="object"
            class="oe_highlight"
            states="wait"/>

    <button name="action_cancel"
            string="Từ chối"
            type="object"
            states="wait"/>
    <button name="action_export_excel"
        string="Xuất Excel"
        type="object"
        class="oe_highlight"
        states="approved"/>
    <field name="state"
           widget="statusbar"
           statusbar_visible="draft,wait,approved,cancel"/>
</header>

                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Mã yêu cầu"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="department_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="request_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="approver_id"
       options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>

                        <group>
                            <field name="date"/>
                            <field name="date_approve" readonly="1"/>
                            <field name="total_qty" readonly="1"/>
                            <field name="total_amount" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sản phẩm">
                            <field name="request_line_ids">
                                <tree editable="bottom">
                                    <field name="state" invisible="1"/>

                                    <field name="product_id"
                                         options="{'no_create': True, 'no_create_edit': True}"
                                         attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                                    <field name="uom_id"
                                          options="{'no_create': True, 'no_create_edit': True}"
                                          attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                                    <field name="qty"
                                          attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                                    <field name="qty_approve"
                                           attrs="{'readonly': [('state', '!=', 'wait')]}"/>

                                    <field name="price_unit"
                                           attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                                    <field name="total" readonly="1"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Mô tả">
    <group>
        <field name="description"/>
        <field name="reject_reason"
               readonly="1"
               attrs="{'invisible': [('state', '!=', 'cancel')]}"/>
    </group>
</page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_purchase_request" model="ir.actions.act_window">
        <field name="name">Yêu cầu mua hàng</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="view_purchase_request_line_tree" model="ir.ui.view">
        <field name="name">purchase.request.line.tree</field>
        <field name="model">purchase.request.line</field>
        <field name="arch" type="xml">
            <tree string="Chi tiết yêu cầu mua hàng" create="false" edit="false" delete="false">
                <field name="request_id"/>
                <field name="product_id"/>
                <field name="uom_id"/>
                <field name="qty"/>
                <field name="qty_approve"/>
                <field name="price_unit"/>
                <field name="total"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_purchase_request_line_form" model="ir.ui.view">
        <field name="name">purchase.request.line.form</field>
        <field name="model">purchase.request.line</field>
        <field name="arch" type="xml">
            <form string="Chi tiết yêu cầu mua hàng" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <field name="request_id" readonly="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="uom_id" readonly="1"/>
                        <field name="qty" readonly="1"/>
                        <field name="qty_approve" readonly="1"/>
                        <field name="price_unit" readonly="1"/>
                        <field name="total" readonly="1"/>
                        <field name="state" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_purchase_request_line" model="ir.actions.act_window">
        <field name="name">Chi tiết yêu cầu mua hàng</field>
        <field name="res_model">purchase.request.line</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>